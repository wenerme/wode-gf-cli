{
  "name": "wode-gf-cli",
  "version": "0.1.0",
  "description": "CLI for exporting and managing Grafana resources",
  "license": "MIT",
  "type": "module",
  "bin": {
    "wode-gf-cli": "./dist/wode-gf-cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/main.ts",
    "build": "bun build src/main.ts --outfile dist/wode-gf-cli.js --target node --minify",
    "postbuild": "chmod +x dist/wode-gf-cli.js",
    "install:bin": "pnpm run build && mkdir -p \"$HOME/bin\" && cp dist/wode-gf-cli.js \"$HOME/bin/wode-gf-cli\" && chmod +x \"$HOME/bin/wode-gf-cli\"",
    "lint": "biome check .",
    "format": "biome check --write .",
    "check": "pnpm run lint && pnpm run build"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@types/node": "^25.5.2",
    "bun-types": "^1.3.11",
    "commander": "^14.0.3",
    "typescript": "^6.0.2",
    "zod": "^4.1.12"
  }
}
